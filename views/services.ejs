<%- include('partials/header') %>

<!-- ── SERVICES HERO ── -->
<section class="svc-hero">
  <div class="svc-hero-bg">
    <div class="svc-hero-orb svc-hero-orb-1"></div>
    <div class="svc-hero-orb svc-hero-orb-2"></div>
    <div class="svc-hero-orb svc-hero-orb-3"></div>
    <div class="svc-hero-grid-overlay"></div>
  </div>
  <div class="container">
    <div class="svc-hero-layout reveal">
      <div class="svc-hero-content">
        <div class="svc-hero-eyebrow">
          <span class="svc-eyebrow-line"></span>
          <span class="section-label">What We Offer</span>
        </div>
        <h1>Integrated<br><span class="svc-hero-accent">Sustainability</span><br>Advisory</h1>
        <p>Five specialized divisions. Forty-five expert services. One purpose — to make sustainability the foundation of your business strategy and operations.</p>
        <div class="svc-hero-stats">
          <div class="svc-hero-stat">
            <span class="svc-stat-num">5</span>
            <span class="svc-stat-label">Advisory Divisions</span>
          </div>
          <div class="svc-hero-stat-divider"></div>
          <div class="svc-hero-stat">
            <span class="svc-stat-num">45</span>
            <span class="svc-stat-label">Expert Services</span>
          </div>
          <div class="svc-hero-stat-divider"></div>
          <div class="svc-hero-stat">
            <span class="svc-stat-num">360°</span>
            <span class="svc-stat-label">Full Coverage</span>
          </div>
        </div>
      </div>
      <div class="svc-hero-visual">
        <div class="svc-division-preview">
          <% services.forEach((cat, i) => { %>
          <div class="svc-preview-item" style="--i: <%= i %>">
            <span class="svc-preview-letter"><%= cat.letter %></span>
            <div class="svc-preview-info">
              <span class="svc-preview-name"><%= cat.category %></span>
              <span class="svc-preview-count"><%= cat.items.length %> services</span>
            </div>
            <svg class="svc-preview-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── SERVICES NAVIGATION BAR ── -->
<section class="services-nav-bar" id="servicesNavBar">
  <div class="services-nav-inner">
    <div class="services-nav-track" id="servicesNavTrack">
      <div class="svc-pill-slider" id="svcPillSlider"></div>
      <div class="svc-underline-slider" id="svcUnderlineSlider"></div>
      <% services.forEach((cat, i) => { %>
        <a href="#<%= cat.id %>" class="svc-nav-link" data-index="<%= i %>" aria-label="Division <%= cat.letter %>">
          <span class="svc-dot"></span>
          <span class="svc-nav-text">
            <span class="svc-nav-letter"><%= cat.letter %></span>
            <%= cat.category %>
          </span>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── SERVICE CATEGORIES ── -->
<div class="services-page">
  <% services.forEach((cat, catIdx) => { %>
  <section class="service-category" id="<%= cat.id %>" data-svc-index="<%= catIdx %>">
    <div class="container">

      <!-- Category Header -->
      <div class="svc-cat-header reveal">
        <div class="svc-cat-header-left">
          <div class="svc-cat-letter-badge">
            <span class="svc-cat-letter-inner"><%= cat.letter %></span>
            <div class="svc-cat-letter-glow"></div>
          </div>
          <div class="svc-cat-meta">
            <span class="svc-cat-division">Division <%= cat.letter %></span>
            <h2><%= cat.category %></h2>
          </div>
        </div>
        <div class="svc-cat-header-right">
          <span class="svc-cat-count"><%= cat.items.length %> Services</span>
        </div>
      </div>

      <div class="svc-cat-line"></div>

      <!-- Services Grid -->
      <div class="svc-grid">
        <% cat.items.forEach((item, i) => { %>
        <div class="svc-card reveal" style="--delay: <%= i * 60 %>ms">
          <div class="svc-card-top">
            <span class="svc-card-index"><%= String(i + 1).padStart(2, '0') %></span>
            <div class="svc-card-dot-accent"></div>
          </div>
          <div class="svc-card-body">
            <h3><%= item.name %></h3>
            <p><%= item.description %></p>
          </div>
          <a href="/quote" class="svc-card-link">
            <span>Get Started</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <div class="svc-card-border-glow"></div>
        </div>
        <% }) %>
      </div>

    </div>
  </section>
  <% }) %>
</div>

<!-- ── CTA SECTION ── -->
<section class="section svc-cta-section">
  <div class="container">
    <div class="svc-cta-card reveal">
      <div class="svc-cta-bg-pattern"></div>
      <div class="svc-cta-content">
        <span class="section-label light">Get Started</span>
        <h2>Need a Custom<br>Sustainability Strategy?</h2>
        <p>Every business is unique. Contact Tureko and we'll design a service package aligned with your specific environmental goals, operational reality, and industry context.</p>
        <div class="svc-cta-actions">
          <a href="/quote" class="btn-primary">Request a Quote</a>
          <a href="/careers" class="btn-outline">Join Our Team</a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
