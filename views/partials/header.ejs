<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <link rel="icon" type="image/jpeg" href="/images/logo.jpg" />
  <meta name="description"
    content="Tureko is a premium sustainability consultancy, tourism advisory, and green workforce placement agency committed to climate-responsible innovation." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/output.css" />
</head>

<body>
  <!-- Opening animation (only on first load) -->
  <div id="intro-overlay">
    <span id="intro-text">tureko</span>
  </div>

  <!-- Navbar -->
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <img src="/images/logo.jpg" alt="Tureko" />
        <span class="nav-wordmark">tureko</span>
      </a>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="navLinks">
        <li><a href="/" class="nav-link">Home</a></li>
        <li><a href="/services" class="nav-link">Services</a></li>
        <li><a href="/quote" class="nav-link">Request a Quote</a></li>
        <li><a href="/careers" class="nav-link">Become Us</a></li>
        <li><a href="/quote" class="nav-cta">Get Started</a></li>
      </ul>
    </div>
  </nav>

  <main id="main-content">